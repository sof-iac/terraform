steps {  
    script {  
        // Usando credenciais para o token  
        withCredentials([string(credentialsId: 'user_svc_jenkins_token', variable: 'GIT_TOKEN')]) {  
            checkout([$class: 'GitSCM',  
                      branches: [[name: '*/main']],  
                      extensions: [  
                          [$class: 'SparseCheckoutPaths',   
                           sparseCheckoutPaths: [  
                               [$class: 'SparseCheckoutPath', path: "${Diretorio}/${Ambiente}/${Site}/${Grupo}"]  
                           ]  
                          ]  
                      ],  
                      userRemoteConfigs: [[  
                          url: 'https://git.sof.intra/infra/terraform.git',   
                          credentialsId: 'user_svc_jenkins_token' // Aqui você pode usar diretamente o ID  
                      ]]  
            ])  
        }  
    }  
}