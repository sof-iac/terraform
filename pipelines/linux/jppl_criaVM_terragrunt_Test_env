pipeline {
    agent any
    parameters {
      // Nome do projeto no gitea
      choice(name: 'Projeto', choices: ['infra', 'devops', 'labcoinf','siop'], description: 'Organização Gitea')
      choice(name: 'Diretorio', choices: ['envs','aws'], description: 'Diretorio raiz') 
      choice(name: 'Ambiente', choices: ['base','test','lab','prod'], description: 'Ambiente')
      choice(name: 'Site', choices: [ 'vsphere-516', 'vsphere-k'], description: 'Site')
      string(name: 'Grupo', defaultValue: 'nome_do_grupo', description: 'Nome do grupo das VMs')
      choice(name: 'init', choices: [ 'nao', 'init', 'init -reconfigure','init -migrate-state','init -upgrade'], description: 'Alterações no Tfsate')
      choice(name: 'lock', choices: ['true','false'], description: 'Lock do dynamodb')    
      choice(name: 'distro', choices: ['ubuntu','alma', 'centos', 'orcl','rocklinux'], description: 'Distribuição Linux')  
      //password(name: 'VM_PASS', description: 'Senha para a máquina virtual')
    }
    environment {
       TF_VAR_VM_PASS = credentials('ansible_pass_text') // Usando credenciais do ansible 
       VAULT_ADDR = 'https://vault.app.sof.intra' // URL do seu servidor Vault  
       VAULT_TOKEN = credentials('vault_token_text') // Usando credenciais do Jenkins  
       ANSIBLE_PASSWD = credentials('ansible_pass_text') // Usando credenciais do ansible 
       TF_VAR_hostname_vcenter_516 = 'your_vcenter_516_hostname' // Substitua pelo valor real
       TF_VAR_hostname_vcenter_k = 'your_vcenter_k_hostname' // Substitua pelo valor real
    }
    stages { 
      stage('Retornando as chaves publica e certificados') {
        steps {
            script {
              dir("${Diretorio}/${Ambiente}/${Site}") {
                // Retorna a chave de conexao com o vcenter
                def secrets_vcenter = [
                    [path: 'secrets/servicos/user_svc_jenkins', engineVersion: 2, secretValues: [
                        [envVar: 'passwd_vcenter', vaultKey: 'password']]]
                ]               

                // optional configuration
                def configuration = [vaultUrl: 'https://vault.app.sof.intra',
                                      vaultCredentialId: 'vault_approle_jenkins',
                                      engineVersion: 2]

                withVault([configuration: configuration, vaultSecrets: secrets_vcenter]) {
                  // Criando secrets.json sem expor senha nos logs
                  // set +x desabilita o modo verbose
                  sh '''
                    set +x
                    cat > secrets.json << SECRETS_EOF
                    {
                      "username_vcenter": "user_svc_jenkins",
                      "passwd_vcenter": "$passwd_vcenter"
                    }
                    SECRETS_EOF
                    chmod 600 secrets.json
                  '''                   
                }
                withCredentials([ 
                    string(credentialsId: 'access_key_teste', variable: 'TF_VAR_access_key_test'),
                    string(credentialsId: 'secret_key_teste', variable: 'TF_VAR_secret_key_test'),
                    string(credentialsId: 'TF_VAR_hostname_vcenter_516', variable: 'VCENTER_HOST_516'),
                    string(credentialsId: 'TF_VAR_username_vcenter_516', variable: 'VCENTER_USER_516'),
                    string(credentialsId: 'TF_VAR_password_vcenter_516', variable: 'VCENTER_PASS_516'),
                    string(credentialsId: 'TF_VAR_hostname_vcenter_k', variable: 'VCENTER_HOST_K'),
                    string(credentialsId: 'TF_VAR_username_vcenter_k', variable: 'VCENTER_USER_K'),
                    string(credentialsId: 'TF_VAR_password_vcenter_k', variable: 'VCENTER_PASS_K')
                ]) {
                // Definindo variáveis locais (não env.*) para evitar log automático
                def vcenter_host = "${Site}" == 'vsphere-516' ? "$VCENTER_HOST_516" : "$VCENTER_HOST_K"
                def vcenter_user = "${Site}" == 'vsphere-516' ? "$VCENTER_USER_516" : "$VCENTER_USER_K"
                def vcenter_pass = "${Site}" == 'vsphere-516' ? "$VCENTER_PASS_516" : "$VCENTER_PASS_K"
                
                // Armazenando em variáveis de ambiente apenas quando necessário, dentro do escopo withCredentials
                env.VCENTER_HOST = vcenter_host
                env.VCENTER_USER = vcenter_user
                env.VCENTER_PASS = vcenter_pass
                    
                // Definindo variáveis de ambiente adicionais
                env.TF_VAR_backend_access_key_test = "$TF_VAR_access_key_test"
                env.TF_VAR_backend_secret_key_test = "$TF_VAR_secret_key_test"
                
                // Criando bucket.json sem expor credenciais nos logs
                // set +x desabilita o modo verbose
                sh '''
                  set +x
                  cat > bucket.json << BUCKET_EOF
                  {
                    "TF_VAR_backend_access_key": "$TF_VAR_access_key_test",
                    "TF_VAR_backend_secret_key": "$TF_VAR_secret_key_test"
                  }
                  BUCKET_EOF
                  chmod 600 bucket.json
                '''
                }
            }
          }
        }
      }   
      stage('Copy terragrunt.hcl') {
          steps {
              script {
                  sh '''
                      cp pipelines/conf/terragrunt.hcl envs/
                  '''
              }
          }
      }            
      stage('Executa Terraform Init') {
          when {
              not { equals expected: 'nao', actual: params.init }
          }
          steps {
              script {
                  dir("${Diretorio}/${Ambiente}/${Site}/${Grupo}") {
                    // Verificando se as variáveis de backend estão definidas
                    if (!env.TF_VAR_backend_access_key_test || !env.TF_VAR_backend_secret_key_test) {
                        error("Variáveis de backend não foram definidas corretamente. TF_VAR_backend_access_key_test ou TF_VAR_backend_secret_key_test estão vazias.")
                    }
                    // Construindo o nome correto da variável de ambiente que o Terragrunt espera
                    def backend_access_key_var = "TF_VAR_backend_access_key_${Ambiente}"
                    def backend_secret_key_var = "TF_VAR_backend_secret_key_${Ambiente}"
                    withEnv(["TF_VAR_VM_PASS=$ANSIBLE_PASSWD", "TF_VAR_DISTRO=$Distro", "VCENTER_HOST=$VCENTER_HOST", "VCENTER_USER=$VCENTER_USER", "VCENTER_PASS=$VCENTER_PASS", "${backend_access_key_var}=${env.TF_VAR_backend_access_key_test}", "${backend_secret_key_var}=${env.TF_VAR_backend_secret_key_test}"]) {  
                          // Comandos que usam as variáveis definidas  
                          // set +x desabilita o modo verbose para não expor senhas nos logs
                          // Usando aspas simples triplas para evitar interpolação do Groovy
                          sh ''' 
                              set +x
                              export TF_LOG=INFO
                              export AWS_VERIFY_SSL=false 
                              terragrunt ''' + init + ''' 
                          ''' 
                      }         
                }
             }
          }
        }        
      stage('Terragrunt Plan') {
          steps {
              script {           
                  dir("${Diretorio}/${Ambiente}/${Site}/${Grupo}") {
                      // Verificando se as variáveis de backend estão definidas
                      if (!env.TF_VAR_backend_access_key_test || !env.TF_VAR_backend_secret_key_test) {
                          error("Variáveis de backend não foram definidas corretamente. TF_VAR_backend_access_key_test ou TF_VAR_backend_secret_key_test estão vazias.")
                      }
                      // Construindo o nome correto da variável de ambiente que o Terragrunt espera
                      def backend_access_key_var = "TF_VAR_backend_access_key_${Ambiente}"
                      def backend_secret_key_var = "TF_VAR_backend_secret_key_${Ambiente}"
                      // Definindo variáveis de ambiente adicionais
                      // env.TF_VAR_backend_access_key = credentials("TF_VAR_backend_access_key_${env}")
                     // env.TF_VAR_backend_secret_key = credentials("TF_VAR_backend_secret_key_${env}")

                      withEnv(["TF_VAR_VM_PASS=$ANSIBLE_PASSWD", "TF_VAR_DISTRO=$Distro", "VCENTER_HOST=$VCENTER_HOST", "VCENTER_USER=$VCENTER_USER", "VCENTER_PASS=$VCENTER_PASS", "${backend_access_key_var}=${env.TF_VAR_backend_access_key_test}", "${backend_secret_key_var}=${env.TF_VAR_backend_secret_key_test}"]) {  
                          // Comandos que usam as variáveis definidas  
                          // set +x desabilita o modo verbose para não expor senhas nos logs
                          // Usando aspas simples triplas para evitar interpolação do Groovy
                          sh ''' 
                              set +x
                              export TF_LOG=INFO
                              export AWS_VERIFY_SSL=false 
                              terragrunt plan -lock=''' + lock + ''' 
                          ''' 
                      }     
                  }                       
              }          
          }
      }  
      stage('Terragrunt Apply') {
          steps {
              script {           
                  dir("${Diretorio}/${Ambiente}/${Site}/${Grupo}") {
                      // Verificando se as variáveis de backend estão definidas
                      if (!env.TF_VAR_backend_access_key_test || !env.TF_VAR_backend_secret_key_test) {
                          error("Variáveis de backend não foram definidas corretamente. TF_VAR_backend_access_key_test ou TF_VAR_backend_secret_key_test estão vazias.")
                      }
                      // Construindo o nome correto da variável de ambiente que o Terragrunt espera
                      def backend_access_key_var = "TF_VAR_backend_access_key_${Ambiente}"
                      def backend_secret_key_var = "TF_VAR_backend_secret_key_${Ambiente}"
                      // Definindo variáveis de ambiente adicionais
                      // env.TF_VAR_backend_access_key = credentials("TF_VAR_backend_access_key_${env}")
                     // env.TF_VAR_backend_secret_key = credentials("TF_VAR_backend_secret_key_${env}")

                      withEnv(["TF_VAR_VM_PASS=$ANSIBLE_PASSWD", "TF_VAR_DISTRO=$Distro", "VCENTER_HOST=$VCENTER_HOST", "VCENTER_USER=$VCENTER_USER", "VCENTER_PASS=$VCENTER_PASS", "${backend_access_key_var}=${env.TF_VAR_backend_access_key_test}", "${backend_secret_key_var}=${env.TF_VAR_backend_secret_key_test}"]) {  
                          // Comandos que usam as variáveis definidas  
                          // set +x desabilita o modo verbose para não expor senhas nos logs
                          // Usando aspas simples triplas para evitar interpolação do Groovy
                          sh ''' 
                              set +x
                              export TF_LOG=INFO
                              export AWS_VERIFY_SSL=false 
                              terragrunt apply -auto-approve -lock=''' + lock + ''' 
                          ''' 
                      }     
                  }                       
              }          
          }
      }        
    }
}
