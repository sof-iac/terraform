pipeline {
    agent any
    
    parameters {
        choice(name: 'Projeto', choices: ['infra', 'devops', 'labcoinf','siop'], description: 'Organização Gitea')
        choice(name: 'Diretorio', choices: ['envs','aws'], description: 'Diretorio raiz') 
        choice(name: 'Ambiente', choices: ['base','test','lab','prod'], description: 'Ambiente')
        choice(name: 'Site', choices: [ 'vsphere-516', 'vsphere-k'], description: 'Site')
        string(name: 'Grupo', defaultValue: 'nome_do_grupo', description: 'Nome do grupo das VMs')
        choice(name: 'init', choices: [ 'nao', 'init', 'init -reconfigure','init -upgrade'], description: 'Comando Init')
        choice(name: 'lock', choices: ['true','false'], description: 'Lock do state')    
        choice(name: 'distro', choices: ['ubuntu','alma', 'centos', 'orcl','rocklinux'], description: 'Distribuição Linux')
        string(name: 'ForceUnlockLockId', defaultValue: '', description: 'Se preenchido, executa terragrunt force-unlock com este ID (ex: 6551fe26-be77-3a8c-38ea-465056314a0c). Use quando o state ficar travado.')
    }

    environment {
        // Variáveis globais simples
        //ANSIBLE_PASSWD = credentials('ansible_pass_text')
        
        // Configurações globais do Terraform para evitar logs sujos e ignorar SSL
        TF_IN_AUTOMATION = 'true'
        AWS_VERIFY_SSL   = 'false'
    }

    stages {
        stage('Prepare Environment') {
            steps {
                script {
                    // Copia o HCL padrão para o local de uso
                    sh 'cp pipelines/conf/terragrunt.hcl envs/ || true' 
                    // O "|| true" evita falha se o arquivo já existir ou caminho for diferente
                }
            }
        }

        stage('Terragrunt Plan') {
            steps {
                script {
                    def minioCredId = "minio-creds-${params.Ambiente}"

                    echo "DEBUG Credentials: minioCredId=${minioCredId} | ambiente=${params.Ambiente} | site=${params.Site}"

                    dir("${Diretorio}/${Ambiente}/${Site}/${Grupo}") {
                        // vCenter: hostname, user e pass vindos de Credentials (Secret text), igual ao pipeline copy
                        withCredentials([
                            usernamePassword(credentialsId: minioCredId,
                                           usernameVariable: 'AWS_ACCESS_KEY_ID',
                                           passwordVariable: 'AWS_SECRET_ACCESS_KEY'),
                            string(credentialsId: 'TF_VAR_hostname_vcenter_516', variable: 'VCENTER_HOST_516'),
                            string(credentialsId: 'TF_VAR_username_vcenter_516', variable: 'VCENTER_USER_516'),
                            string(credentialsId: 'TF_VAR_password_vcenter_516', variable: 'VCENTER_PASS_516'),
                            string(credentialsId: 'TF_VAR_hostname_vcenter_k', variable: 'VCENTER_HOST_K'),
                            string(credentialsId: 'TF_VAR_username_vcenter_k', variable: 'VCENTER_USER_K'),
                            string(credentialsId: 'TF_VAR_password_vcenter_k', variable: 'VCENTER_PASS_K'),
                            string(credentialsId: 'ansible_pass_text', variable: 'TF_VAR_VM_PASS')
                        ]) {
                            // Escolhe host/user/pass do vCenter conforme o Site (igual ao copy)
                            env.VSPHERE_SERVER   = (params.Site == 'vsphere-516') ? env.VCENTER_HOST_516 : env.VCENTER_HOST_K
                            env.VSPHERE_USER    = (params.Site == 'vsphere-516') ? env.VCENTER_USER_516 : env.VCENTER_USER_K
                            env.VSPHERE_PASSWORD = (params.Site == 'vsphere-516') ? env.VCENTER_PASS_516 : env.VCENTER_PASS_K
                            // Force-unlock do state quando o lock ficou travado (ex.: após erro ao liberar lock no MinIO)
                            if (params.ForceUnlockLockId?.trim()) {
                                echo "Executando force-unlock com Lock ID: ${params.ForceUnlockLockId.trim()}"
                                sh "terragrunt force-unlock -force ${params.ForceUnlockLockId.trim()}"
                            }
                            // DEBUG (sem exibir valores)
                            sh '''
                                echo "DEBUG AWS_ACCESS_KEY_ID: set=${AWS_ACCESS_KEY_ID:+yes} length=${#AWS_ACCESS_KEY_ID}"
                                echo "DEBUG AWS_SECRET_ACCESS_KEY: set=${AWS_SECRET_ACCESS_KEY:+yes} length=${#AWS_SECRET_ACCESS_KEY}"
                                echo "DEBUG VSPHERE_SERVER: set=${VSPHERE_SERVER:+yes} length=${#VSPHERE_SERVER}"
                                echo "DEBUG VSPHERE_USER: set=${VSPHERE_USER:+yes} length=${#VSPHERE_USER}"
                                echo "DEBUG VSPHERE_PASSWORD: set=${VSPHERE_PASSWORD:+yes} length=${#VSPHERE_PASSWORD}"
                                echo "DEBUG TF_VAR_VM_PASS: set=${TF_VAR_VM_PASS:+yes} length=${#TF_VAR_VM_PASS}"
                            '''
                            if (params.init != 'nao') {
                                sh "TF_VAR_DISTRO=${params.distro} terragrunt ${params.init}"
                            }
                            sh "TF_VAR_DISTRO=${params.distro} terragrunt plan -lock=${params.lock}"
                        }
                    }
                }
            }
        }

        stage('Terragrunt Apply') {
            steps {
                script {
                    def minioCredId = "minio-creds-${params.Ambiente}"

                    dir("${Diretorio}/${Ambiente}/${Site}/${Grupo}") {
                        withCredentials([
                            usernamePassword(credentialsId: minioCredId, usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY'),
                            string(credentialsId: 'TF_VAR_hostname_vcenter_516', variable: 'VCENTER_HOST_516'),
                            string(credentialsId: 'TF_VAR_username_vcenter_516', variable: 'VCENTER_USER_516'),
                            string(credentialsId: 'TF_VAR_password_vcenter_516', variable: 'VCENTER_PASS_516'),
                            string(credentialsId: 'TF_VAR_hostname_vcenter_k', variable: 'VCENTER_HOST_K'),
                            string(credentialsId: 'TF_VAR_username_vcenter_k', variable: 'VCENTER_USER_K'),
                            string(credentialsId: 'TF_VAR_password_vcenter_k', variable: 'VCENTER_PASS_K'),
                            string(credentialsId: 'ansible_pass_text', variable: 'TF_VAR_VM_PASS')
                        ]) {
                            env.VSPHERE_SERVER   = (params.Site == 'vsphere-516') ? env.VCENTER_HOST_516 : env.VCENTER_HOST_K
                            env.VSPHERE_USER     = (params.Site == 'vsphere-516') ? env.VCENTER_USER_516 : env.VCENTER_USER_K
                            env.VSPHERE_PASSWORD = (params.Site == 'vsphere-516') ? env.VCENTER_PASS_516 : env.VCENTER_PASS_K
                            sh "TF_VAR_DISTRO=${params.distro} terragrunt apply -auto-approve -lock=${params.lock}"
                        }
                    }
                }
            }
        }
    }
}