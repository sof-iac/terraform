pipeline {
    agent any
    parameters {
      // Nome do projeto no gitea
      choice(name: 'Projeto', choices: ['infra', 'devops', 'labcoinf','siop'], description: 'Organização Gitea')
      choice(name: 'Diretorio', choices: ['envs','aws'], description: 'Diretorio raiz') 
      choice(name: 'Ambiente', choices: ['base','test','lab','prod'], description: 'Ambiente')
      choice(name: 'Site', choices: [ 'vsphere-516', 'vsphere-k'], description: 'Site')
      string(name: 'Grupo', defaultValue: 'nome_do_grupo', description: 'Nome do grupo das VMs')
      choice(name: 'init', choices: [ 'nao', 'init', 'init -reconfigure','init -migrate-state'], description: 'Alterações no Tfsate')
      choice(name: 'lock', choices: ['true','false'], description: 'Lock do dynamodb')
      password(name: 'GITEA_TOKEN', description: 'Token gitea')
      text(name: 'URL', defaultValue: 'https://${GITEA_TOKEN}@gitea.app.sof.intra', description: 'URL do Repo')     
      choice(name: 'distro', choices: ['ubuntu', 'centos', 'orcl','rocklinux'], description: 'Distribuição Linux')  
      //password(name: 'VM_PASS', description: 'Senha para a máquina virtual')
    }
    environment {
       TF_VAR_VM_PASS = credentials('ansible_pass_text') // Usando credenciais do ansible 
       VAULT_ADDR = 'https://vault.app.sof.intra' // URL do seu servidor Vault  
       VAULT_TOKEN = credentials('vault_token_text') // Usando credenciais do Jenkins  
       ANSIBLE_PASSWD = credentials('ansible_pass_text') // Usando credenciais do ansible 
       //GITEA_TOKEN = credentials('GITEA_TOKEN') // Usando credenciais do gitea
       //giteaacesstoken = credentials('giteaacesstoken') // Usando credenciais do gitea
       //GITEA_CREDENTIALS = credentials('GITEA_TOKEN')
       TF_VAR_hostname_vcenter_516 = 'your_vcenter_516_hostname' // Substitua pelo valor real
       TF_VAR_hostname_vcenter_k = 'your_vcenter_k_hostname' // Substitua pelo valor real
    }
    stages {
      stage('Download Certificate') {  
        steps {  
            script {  
                // Exemplo: O caminho do segredo que contém o certificado  
                def secretPath = 'secrets/certificados/minio.sof.intra'  
                def outputFile = '/etc/ssl/certs/minio.pem'  

                // Comando para baixar o certificado  
                def command = """  
                    export VAULT_ADDR=${env.VAULT_ADDR}  
                    export VAULT_TOKEN=${env.VAULT_TOKEN}
                    vault kv get -field=minio_cert ${secretPath} > ${outputFile}  
                    
                """  
                // Executa o comando  
                sh sudo command  
            }  
        }  
      } 
      stage('Retornando as chaves publica e certificados') {
        steps {
            script {
              dir("${Diretorio}/${Ambiente}/${Site}") {
                // Retorna a chave de conexao com o vcenter
                def secrets_vcenter = [
                    [path: 'secrets/servicos/user_svc_jenkins', engineVersion: 2, secretValues: [
                        [envVar: 'passwd_vcenter', vaultKey: 'password']]]
                ]               

                // optional configuration
                def configuration = [vaultUrl: 'https://vault.app.sof.intra',
                                      vaultCredentialId: 'token_vault',
                                      engineVersion: 2]

                withVault([configuration: configuration, vaultSecrets: secrets_vcenter]) {
                  sh "echo '{\\n  \"username_vcenter\": \"user_svc_jenkins\",\\n  \"passwd_vcenter\": \"$passwd_vcenter\"\\n}' > secrets.json"                   
                }
                withCredentials([ 
                    string(credentialsId: 'access_key_prod', variable: 'TF_VAR_access_key_prod'),
                    string(credentialsId: 'secret_key_prod', variable: 'TF_VAR_secret_key_prod'),
                    string(credentialsId: 'TF_VAR_hostname_vcenter_516', variable: 'VCENTER_HOST_516'),
                    string(credentialsId: 'TF_VAR_username_vcenter_516', variable: 'VCENTER_USER_516'),
                    string(credentialsId: 'TF_VAR_password_vcenter_516', variable: 'VCENTER_PASS_516'),
                    string(credentialsId: 'TF_VAR_hostname_vcenter_k', variable: 'VCENTER_HOST_K'),
                    string(credentialsId: 'TF_VAR_username_vcenter_k', variable: 'VCENTER_USER_K'),
                    string(credentialsId: 'TF_VAR_password_vcenter_k', variable: 'VCENTER_PASS_K')
                ]) {
                if("${Site}" == 'vsphere-516') {
                    env.VCENTER_HOST = "$VCENTER_HOST_516"
                    env.VCENTER_USER = "$VCENTER_USER_516"
                    env.VCENTER_PASS = "$VCENTER_PASS_516"
                } else {
                    env.VCENTER_HOST = "$VCENTER_HOST_K"
                    env.VCENTER_USER = "$VCENTER_USER_K"
                    env.VCENTER_PASS = "$VCENTER_PASS_K"
                }                    
                  // Definindo variáveis de ambiente adicionais
                  env.TF_VAR_backend_access_key_prod = "$TF_VAR_access_key_prod"
                  env.TF_VAR_backend_secret_key_prod = "$TF_VAR_secret_key_prod"
                  sh " echo '{\\n  \"TF_VAR_backend_access_key\": \"$TF_VAR_access_key_prod\",\\n  \"TF_VAR_backend_secret_key\": \"$TF_VAR_secret_key_prod\"\\n}' > bucket.json"
                }
            }
          }
        }
      }   
      stage('Copy terragrunt.hcl') {
          steps {
              script {
                  sh '''
                      cp pipelines/conf/terragrunt.hcl envs/
                  '''
              }
          }
      }                    
      stage('Terragrunt Plan') {
          steps {
              script {           
                  dir("${Diretorio}/${Ambiente}/${Site}/${Grupo}") {
                      // Definindo variáveis de ambiente adicionais
                      // env.TF_VAR_backend_access_key = credentials("TF_VAR_backend_access_key_${env}")
                     // env.TF_VAR_backend_secret_key = credentials("TF_VAR_backend_secret_key_${env}")

                      withEnv(["TF_VAR_VM_PASS=$ANSIBLE_PASSWD", "TF_VAR_DISTRO=$Distro", "VCENTER_HOST=$VCENTER_HOST", "VCENTER_USER=$VCENTER_USER", "VCENTER_PASS=$VCENTER_PASS"]) {  
                          // Comandos que usam as variáveis definidas  

                          sh """ 
                              export TF_LOG=DEBUG  
                              export TF_VAR_VM_PASS=${ANSIBLE_PASSWD}
                              export TF_VAR_DISTRO=${Distro}  
                              export VCENTER_HOST=${VCENTER_HOST}
                              export VCENTER_PASS=${VCENTER_PASS}
                              export VCENTER_USER=${VCENTER_USER}
                              export TF_VAR_backend_access_key_prod=${env.TF_VAR_backend_access_key_prod}
                              export TF_VAR_backend_secret_key_prod=${env.TF_VAR_backend_secret_key_prod}
                              export AWS_VERIFY_SSL=false 
                              terragrunt plan -lock=${lock} 
                          """ 
                      }     
                  }                       
              }          
          }
      }  
      stage('Terragrunt Apply') {
          steps {
              script {           
                  dir("${Diretorio}/${Ambiente}/${Site}/${Grupo}") {
                      // Definindo variáveis de ambiente adicionais
                      // env.TF_VAR_backend_access_key = credentials("TF_VAR_backend_access_key_${env}")
                     // env.TF_VAR_backend_secret_key = credentials("TF_VAR_backend_secret_key_${env}")

                      withEnv(["TF_VAR_VM_PASS=$ANSIBLE_PASSWD", "TF_VAR_DISTRO=$Distro", "VCENTER_HOST=$VCENTER_HOST", "VCENTER_USER=$VCENTER_USER", "VCENTER_PASS=$VCENTER_PASS"]) {  
                          // Comandos que usam as variáveis definidas  

                          sh """ 
                              export TF_LOG=DEBUG  
                              export TF_VAR_VM_PASS=${ANSIBLE_PASSWD}
                              export TF_VAR_DISTRO=${Distro}  
                              export VCENTER_HOST=${VCENTER_HOST}
                              export VCENTER_PASS=${VCENTER_PASS}
                              export VCENTER_USER=${VCENTER_USER}
                              export TF_VAR_backend_access_key_prod=${env.TF_VAR_backend_access_key_prod}
                              export TF_VAR_backend_secret_key_prod=${env.TF_VAR_backend_secret_key_prod}
                              export AWS_VERIFY_SSL=false 
                              terragrunt apply -auto-approve -lock=${lock}
                          """ 
                      }     
                  }                       
              }          
          }
      }        
    }
}
