pipeline {
    agent any
    environment {
      VAULT_PATH = 'secrets/secrets/servicos/ansible/ansible'
    }
    parameters {
      // Nome do projeto no gitea
      choice(name: 'Projeto', choices: ['infra', 'devops', 'labcoinf','siop'], description: 'Organização Gitea')
      choice(name: 'Datacenter', choices: ['vsphere-sof','aws'], description: 'Datacenter') 
      choice(name: 'Site', choices: [ 'sof', 'blocok'], description: 'Site')
      choice(name: 'Ambiente', choices: ['teste','lab','prod'], description: 'Ambiente')
      string(name: 'Diretorio', defaultValue: 'vm_teste', description: 'Nome do diretorio do projeto Terraform a executar')
      choice(name: 'init', choices: [ 'nao', 'init', 'init -reconfigure','init -migrate-state'], description: 'Alterações no Tfsate')
      choice(name: 'lock', choices: ['true','false'], description: 'Lock do dynamodb')
      password(name: 'GITEA_TOKEN', description: 'Token gitea')
      text(name: 'URL', defaultValue: 'https://${GITEA_TOKEN}@gitea.app.sof.intra', description: 'URL do Repo')     
      choice(name: 'distro', choices: ['ubuntu', 'centos', 'orcl','rocklinux'], description: 'Distribuição Linux')  
      string(name: 'vm_user', defaultValue: 'root', description: 'Nome de usuário para a máquina virtual')
      password(name: 'vm_pass', description: 'Senha para a máquina virtual')
      string(name: 'svc_username', defaultValue: 'ansible', description: 'Usuario ansible')
      password(name: 'svc_password', description: 'Senha do ansible')
      password(name: 'user_svc_passwd', description: 'Senha para o Vcenter')
      string(name: 'public_key', defaultValue: 'ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIJvaUICPun0zJo21vhsvaZpYegvpzZjxxkMQxPOF5xeL user_svc_puppet.sof.intra', description: 'Chave publica do ansible')
    }

    stages {
      stage('Retornando as chaves privadas e certificados') {
        steps {
            script {
              dir("${Datacenter}/${Site}/envs/${Ambiente}") {
                // define the secrets and the env variables
                def cert_minio = [
                    [path: 'secrets/certificados/minio.sof.intra', engineVersion: 2, secretValues: [
                        [envVar: 'minio.pem', vaultKey: 'minio.pem']]]
                ]
                // Retorna a chave de conexao com o vcenter
                def secrets_vcenter = [
                    [path: 'secrets/servicos/user_svc_vcenter', engineVersion: 2, secretValues: [
                        [envVar: 'user_svc_passwd', vaultKey: 'username']]]
                ]
                // Retorna a chave publica do ansible
                def pk_ansible = [
                    [path: 'secrets/servicos/ansible/ansible', engineVersion: 2, secretValues: [
                        [envVar: 'ansible_pub', vaultKey: 'public_key']]]
                ]                

                // optional configuration
                def configuration = [vaultUrl: 'https://vault.app.sof.intra',
                                      vaultCredentialId: 'token_vault',
                                      engineVersion: 2]

                // inside this block your credentials will be available as env variables
                withVault([configuration: configuration, vaultSecrets: cert_minio]) {
                    sh 'echo $minio.pem > minio.pem'
                }

                withVault([configuration: configuration, vaultSecrets: secrets_vcenter]) {
                    sh 'echo $user_svc_passwd > secrets.txt'
                }

                withVault([configuration: configuration, vaultSecrets: pk_ansible]) {
                    sh 'echo $ansible_pub > id_ed25519.pub'
                }
            }
          }
        }
      }            
      stage('Criando o vars.tf') {
          steps {
              script {
                  // Salva a escolha do usuário em um arquivo
                  dir("${Datacenter}/${Site}/envs/${Ambiente}/${Diretorio}") {
                  writeFile file: 'vars.tf', text: """  
                      variable "vm_user" {
                        description = "Nome de usuario para a máquina virtual"
                        default     = "${vm_user}"
                      }
                      variable "vm_pass" {
                        description = "Senha para a maquina virtual"
                        default     = "${vm_pass}"
                      }                  
                      variable "svc_username" {
                        description = "Usuario do ansible"
                        default     = "${svc_username}"
                      }
                      variable "svc_password" {
                        description = "Senha do ansible"
                        default     = "${svc_password}"
                      }                         
                      variable "public_key" {
                        description = "Chave publica"
                        default     = "${public_key}"
                      }                                                
                      variable "user_svc_passwd" {
                        description = "Senha do DC"
                        default     = "${user_svc_passwd}"
                      }         
                      variable "public_key" {
                        description = "Chave publica"
                        default     = "${public_key}"
                      }                                                                                
                    """
                  }
              }
          }
      }         
      stage('Terragrunt Plan') {
          steps {
            script {           
              dir("${Datacenter}/${Site}/envs/${Ambiente}/${Diretorio}") {     
                // define the secrets and the env variables
                def secrets = [
                    [path: 'secrets/servicos/user_svc_vcenter', engineVersion: 2, secretValues: [
                        [envVar: 'user_svc_passwd', vaultKey: 'username']]]
                ]

                // optional configuration
                def configuration = [vaultUrl: 'https://vault.app.sof.intra',
                                      vaultCredentialId: 'token_vault',
                                      engineVersion: 2]

                // inside this block your credentials will be available as env variables
                withVault([configuration: configuration, vaultSecrets: secrets]) {
                    sh 'echo $user_svc_passwd'
                    if("${init}" != 'nao')
                    {
                       sh """ terragrunt ${init}  """
                    }
                    sh 'pwd'
                    sh 'ls -la '
                    sh """ terragrunt plan -lock=${lock} -var 'user_svc_passwd=${user_svc_passwd}' """ 
                }                            
                
              }
            }          
          }
        }
        stage('Terragrunt Apply') {
          steps {
            script {           
              dir("${Datacenter}/${Site}/envs/${Ambiente}/${Diretorio}") {     
                // define the secrets and the env variables
                def secrets = [
                    [path: 'secrets/servicos/user_svc_vcenter', engineVersion: 2, secretValues: [
                        [envVar: 'user_svc_passwd', vaultKey: 'username']]]
                ]

                // optional configuration
                def configuration = [vaultUrl: 'https://vault.app.sof.intra',
                                      vaultCredentialId: 'token_vault',
                                      engineVersion: 2]

                // inside this block your credentials will be available as env variables
                withVault([configuration: configuration, vaultSecrets: secrets]) {
                    sh 'echo $user_svc_passwd'
                    sh """ terragrunt apply -auto-approve -lock=${lock} -var 'user_svc_passwd=${user_svc_passwd}' """
                }                            
                
              }
            }          
          }                     
        }               
    }
}
